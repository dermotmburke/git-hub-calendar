# Google Calendar OAuth2
# 1. Create a project in Google Cloud Console
# 2. Enable the Google Calendar API
# 3. Create OAuth2 credentials (type: Desktop App)
# 4. Download as auth/credentials.json
# 5. Run: npm run auth  — then copy the refresh_token shown into this file
GOOGLE_CLIENT_ID=id
GOOGLE_CLIENT_SECRET=secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Which calendar to use (leave as "primary" to use your main calendar)
GOOGLE_CALENDAR_ID=primary
