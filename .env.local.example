# Google Calendar OAuth2
# 1. Create a project in Google Cloud Console
# 2. Enable the Google Calendar API
# 3. Create OAuth2 credentials (type: Web application)
#    Add authorised redirect URI: <APP_URL>/api/auth/google/callback
# 4. Copy Client ID and Client Secret below
# 5. Either run: npm run auth  — or visit /admin/auth to connect via the UI
GOOGLE_CLIENT_ID=id
GOOGLE_CLIENT_SECRET=secret
GOOGLE_REFRESH_TOKEN=your-refresh-token   # fallback if auth/token.json is absent

# Base URL of the app — used to build the OAuth callback redirect URI
# Development:  http://localhost:3000
# Production:   https://your-domain.com
APP_URL=http://localhost:3000

# Protects /admin/auth and the OAuth initiation route.
# Set to a strong random string. Visit /admin/auth?secret=<value> to access.
# If unset, the admin page is open to anyone (acceptable for local dev only).
ADMIN_SECRET=

# Which calendar to use (leave as "primary" to use your main calendar)
GOOGLE_CALENDAR_ID=primary

# Slack DM alerts
# 1. Create a Slack App at https://api.slack.com/apps
# 2. Add the chat:write scope under OAuth & Permissions
# 3. Install to workspace and copy the Bot User OAuth Token (starts with xoxb-)
# 4. Find your User ID in Slack: Profile → ⋮ → Copy member ID
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_USER_ID=U01XXXXXXX
